# Copy to .env.local and fill in. Never commit real secrets.

# --- Database (Postgres) ---
# Local example: postgresql://postgres:postgres@localhost:5432/lexcursor
# Hosted (Neon/Supabase): use the connection string they provide.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lexcursor"

# --- Clerk auth ---
# Get these from https://dashboard.clerk.com (API Keys).
# Auth stays OFF until both are present, so the app runs without them.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
