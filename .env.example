# Copy to `.env.local` (local dev) or `.env` (Docker). Never commit real secrets.
# For Vercel: add the same variables in Project Settings → Environment Variables.

# --- Database (Postgres) ---
# Local example: postgresql://postgres:postgres@localhost:5432/briefcaseos
# Hosted (Neon/Supabase): use the connection string they provide.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/briefcaseos"

# --- Clerk auth ---
# Get these from https://dashboard.clerk.com (API Keys).
# Auth stays OFF until both are present, so the app runs without them.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- MCP (Phase 4) ---
# Cursor dev tooling: project `.cursor/mcp.json` (Neon). Reload Cursor after editing.
# Runtime API (`GET /api/mcp`, requires login when Clerk is on):
MCP_SERVER_URL="https://mcp.neon.tech/mcp"
# Neon API key or generic bearer token for the MCP server (never commit real values):
NEON_API_KEY=""
# MCP_API_KEY=""

# --- Docker (Phase 5) ---
# `docker compose up` overrides DATABASE_URL with the local Postgres service.
# Copy this file to `.env`, fill secrets, then: docker compose up --build
